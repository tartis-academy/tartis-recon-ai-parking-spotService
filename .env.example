# Variables del Postgres dedicado de spot-service.
# Copia a .env antes de levantar:
#   cp .env.example .env && docker compose up -d
#
# Estas mismas credenciales van en application.properties
# (spring.datasource.*) para que el servicio se conecte aqui.

SPOT_DB_NAME=spot_db
SPOT_DB_USER=spot_user
SPOT_DB_PASSWORD=change.me

# Puerto EN EL HOST. Dentro de la red parking-shared sigue siendo el 5432.
# Cada servicio usa uno distinto: vehicle 5433, spot 5434, tariff 5435...
SPOT_DB_PORT=5434
